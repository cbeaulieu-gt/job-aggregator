# job-aggregator preflight smoke test — credential template
# Copy this file to .env and fill in your values.
# .env is in .gitignore and is NEVER committed.

# --- Adzuna (https://developer.adzuna.com/) ---
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# --- Jooble (https://jooble.org/api/index) ---
JOOBLE_API_KEY=your_jooble_key_here

# --- JSearch via RapidAPI (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch) ---
JSEARCH_API_KEY=your_rapidapi_key_here

# --- USAJobs (https://developer.usajobs.gov/) ---
USAJOBS_EMAIL=your_registered_email@example.com
USAJOBS_API_KEY=your_usajobs_key_here

# --- No credentials required for these sources ---
# arbeitnow, himalayas, jobicy, remoteok, remotive, the_muse
